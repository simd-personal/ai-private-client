# Private Client Property Desk — copy to .env.local and fill in values

OPENAI_API_KEY=sk-your-openai-key
OPENAI_PREMIUM_MODEL=gpt-5.5
OPENAI_MINI_BACKUP_MODEL=gpt-5.4-mini

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

ADMIN_PASSWORD=your-secure-admin-password
PLATFORM_ADMIN_PASSWORD=your-platform-admin-password
ANALYTICS_IP_SALT=your-random-analytics-salt

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BOOKING_URL=

# Optional — seller property enrichment
RENTCAST_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional — email notifications
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=

# E2E / Playwright (optional — for local, preview, or production validation)
# E2E_BASE_URL can point to localhost, Vercel preview, or production.
E2E_BASE_URL=
# Tenant admin password (matches ADMIN_PASSWORD on the target deployment).
E2E_ADMIN_PASSWORD=
# Platform admin password (matches PLATFORM_ADMIN_PASSWORD on the target deployment).
# For local E2E, ADMIN_PASSWORD is used when this is unset (development only).
E2E_PLATFORM_ADMIN_PASSWORD=
# Used only for Vercel Deployment Protection bypass on protected deployments.
E2E_VERCEL_BYPASS_SECRET=
# Read-only by default — set true only when you intentionally want mutating tests.
E2E_RESET_DEMO=false
E2E_TEST_UPLOADS=false
E2E_CREATE_LEADS=false

# Optional — log generation stage timings (no sensitive data)
DEBUG_GENERATION_TIMING=false
