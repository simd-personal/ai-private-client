# Private Client Property Desk — copy to .env.local and fill in values

OPENAI_API_KEY=sk-your-openai-key
OPENAI_PREMIUM_MODEL=gpt-5.5
OPENAI_MINI_BACKUP_MODEL=gpt-5.4-mini

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

ADMIN_PASSWORD=your-secure-admin-password
PLATFORM_ADMIN_PASSWORD=your-platform-admin-password
ANALYTICS_IP_SALT=your-random-analytics-salt

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BOOKING_URL=

# Optional — seller property enrichment
RENTCAST_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional — email notifications
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=
